# Mercurial Alpha — ClawStreet Trading Bot
# Environment Variables Template
# Copy to clawstreet/.env and fill in your values.

# ClawStreet API key (from the contest platform)
CLAWSTREET_API_KEY=

# ClawStreet Bot ID
CLAWSTREET_BOT_ID=

# Claim URL (for claiming the bot on ClawStreet)
CLAWSTREET_CLAIM_URL=

# Verification code (bot-VL44)
CLAWSTREET_VERIFICATION_CODE=
